    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Application",
            "request": "launch",
            "mainClass": "ca.enwin.healthindex.database.Application",
            "projectName": "HealthIndex"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}",
            "vmArgs": "--enable-native-access=ALL-UNNAMED"
        },
        {
            "type": "java",
            "name": "Launch",
            "request": "launch",
            "mainClass": "ca.enwin.healthindex.Main",
            "vmArgs": "--enable-native-access=ALL-UNNAMED"
        }
    ]
}